# App
APP_NAME=outbox
APP_VERSION=1.0.0
APP_ENV=dev
APP_WORKER_FREQUENCY_SEC=60
APP_BATCH_SIZE=20

# Postgres
POSTGRES_USER=auth-user
POSTGRES_PASSWORD=auth-password
POSTGRES_HOST=postgres-auth
POSTGRES_PORT=5432
POSTGRES_DBNAME=auth-db

# Kafka producer
KAFKA_PRODUCER_ADDR=[]{kafka}
KAFKA_PRODUCER_TOPIC=registration
KAFKA_PRODUCER_RETRY_ATTEMPTS=5
KAFKA_PRODUCER_RETRY_TIMEOUT_SEC=1.0