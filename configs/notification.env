# App
APP_NAME=notification
APP_VERSION=1.0.0
APP_ENV=dev

# Postgres
POSTGRES_USER=notification-user
POSTGRES_PASSWORD=notification-password
POSTGRES_HOST=postgres-notification
POSTGRES_PORT=5432
POSTGRES_DBNAME=notification-db

# Kafka consumer
KAFKA_CONSUMER_ADDR=[]{kafka}
KAFKA_CONSUMER_TOPIC=registration