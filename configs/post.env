# App
APP_NAME=post
APP_VERSION=1.0.0
APP_ENV=dev

# Cache
CACHE_TTL=720min

# Http server
HTTP_HOST=post
HTTP_PORT=8080

# Grpc client
GRPC_CLIENT_HOST=auth
GRPC_CLIENT_PORT=50051
GRPC_CLIENT_IDLE_TIMEOUT=10s

# Postgres
POSTGRES_USER=post-user
POSTGRES_PASSWORD=post-password
POSTGRES_HOST=postgres-post
POSTGRES_PORT=5432
POSTGRES_DBNAME=post-db

# Jwt
TOKEN_ISSUER=auth
TOKEN_FORMAT=DER
TOKEN_ALGORITHM=RS256
TOKEN_KID=auth-05.26