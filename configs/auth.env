# App
APP_NAME=auth
APP_VERSION=1.0.0
APP_ENV=dev

# Jwt
TOKEN_PRIVATE_KEY_PATH=../certs/rs256private.pem
TOKEN_PUBLIC_KEY_PATH=../certs/rs256public.pem
TOKEN_ISSUER=auth
TOKEN_FORMAT=DER
TOKEN_ALGORITHM=RS256
TOKEN_KID=auth-05.26
TOKEN_ACCESS_TTL=15min
TOKEN_REFRESH_TTL=1440min

# Postgres
POSTGRES_USER=auth-user
POSTGRES_PASSWORD=auth-password
POSTGRES_HOST=postgres-auth
POSTGRES_PORT=5432
POSTGRES_DBNAME=auth-db

# Redis
REDIS_USERNAME=redis
REDIS_PASSWORD=redis-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=redis-db
REDIS_TOKEN_TTL=1440min
REDIS_IP_RATE_LIMIT=20
REDIS_IP_RATE_LIMITER_TTL=15min
REDIS_EMAIL_RATE_LIMIT=5
REDIS_EMAIL_RATE_LIMITER_TTL=5min

# Http server
HTTP_HOST=auth
HTTP_PORT=8080

# Grpc server
GRPC_SERVER_PORT=50051