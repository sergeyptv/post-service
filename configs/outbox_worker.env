# App
APP_NAME=outbox_worker
APP_VERSION=1.0.0
APP_ENV=local
APP_WORKER_FREQUENCY_SEC=60

# Postgres
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=auth_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DBNAME=auth_db

# Kafka producer
KAFKA_PRODUCER_ADDR=[]{localhost}
KAFKA_PRODUCER_TOPIC=user.registered
KAFKA_PRODUCER_RETRY_ATTEMPTS=5
KAFKA_PRODUCER_RETRY_TIMEOUT_SEC=1.0